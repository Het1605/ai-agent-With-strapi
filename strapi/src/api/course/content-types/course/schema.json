{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {},
  "attributes": {
    "course_name": {
      "type": "string",
      "required": true
    },
    "course_code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "credits": {
      "type": "integer",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "active",
        "inactive"
      ]
    }
  }
}
