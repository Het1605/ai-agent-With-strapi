{
  "kind": "collectionType",
  "collectionName": "employee_leaves",
  "info": {
    "singularName": "employee-leave",
    "pluralName": "employee-leaves",
    "displayName": "Employee Leave"
  },
  "options": {},
  "attributes": {
    "leave_type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "sick",
        "vacation",
        "personal",
        "maternity",
        "paternity",
        "unpaid"
      ]
    },
    "start_date": {
      "type": "datetime",
      "required": true
    },
    "end_date": {
      "type": "datetime",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    },
    "reason": {
      "type": "text",
      "required": true,
      "minLength": 10
    },
    "employee": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employee.employee"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}
