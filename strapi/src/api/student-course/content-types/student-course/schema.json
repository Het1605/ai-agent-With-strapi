{
  "kind": "collectionType",
  "collectionName": "student_courses",
  "info": {
    "singularName": "student-course",
    "pluralName": "student-courses",
    "displayName": "Student Course"
  },
  "options": {},
  "attributes": {
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student.student"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course"
    },
    "enrollment_date": {
      "type": "date",
      "required": true
    },
    "completion_status": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "enrolled",
        "completed",
        "dropped"
      ]
    }
  }
}
