{
  "kind": "collectionType",
  "collectionName": "salaries",
  "info": {
    "singularName": "salary",
    "pluralName": "salaries",
    "displayName": "Salary"
  },
  "options": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "string",
      "required": true
    },
    "payment_date": {
      "type": "datetime",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "pending",
        "paid",
        "failed"
      ]
    },
    "notes": {
      "type": "text"
    },
    "employee": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employee.employee"
    }
  }
}
