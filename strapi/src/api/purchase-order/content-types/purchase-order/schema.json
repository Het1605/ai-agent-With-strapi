{
  "kind": "collectionType",
  "collectionName": "purchase_orders",
  "info": {
    "singularName": "purchase-order",
    "pluralName": "purchase-orders",
    "displayName": "Purchase Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "order_date": {
      "type": "datetime",
      "required": true
    },
    "Purchase_Order_status": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "pending",
        "received",
        "cancelled"
      ]
    },
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier"
    }
  }
}
