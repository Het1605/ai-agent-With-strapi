{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {},
  "attributes": {
    "first_name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "last_name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "date_of_birth": {
      "type": "date",
      "required": true,
      "unique": false
    },
    "enrollment_date": {
      "type": "date",
      "required": true,
      "unique": false
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "unique": false,
      "default": "active",
      "enum": []
    },
    "address": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::address.address"
    }
  }
}
