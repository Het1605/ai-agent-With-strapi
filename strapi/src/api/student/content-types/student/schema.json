{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {},
  "attributes": {
    "first_name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "last_name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "date_of_birth": {
      "type": "date",
      "required": true,
      "unique": false
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "phone_number": {
      "type": "string",
      "required": false,
      "unique": false
    },
    "address": {
      "type": "text",
      "required": false,
      "unique": false
    },
    "enrollment_date": {
      "type": "date",
      "required": true,
      "unique": false
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "unique": false,
      "default": "active",
      "enum": [
        "active",
        "inactive",
        "graduated"
      ]
    },
    "profile_picture": {
      "type": "media",
      "required": false,
      "unique": false,
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "notes": {
      "type": "text",
      "required": false,
      "unique": false
    }
  }
}
