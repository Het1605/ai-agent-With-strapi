{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "first_name": {
      "type": "string",
      "required": true
    },
    "last_name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "profile_picture": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "date_of_birth": {
      "type": "date"
    },
    "enrollment_date": {
      "type": "date"
    },
    "Student_status": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "active",
        "inactive",
        "graduated",
        "suspended"
      ]
    },
    "phone_number": {
      "type": "string",
      "minLength": 10,
      "maxLength": 15
    },
    "address": {
      "type": "text"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}
