{
  "kind": "collectionType",
  "collectionName": "employees",
  "info": {
    "singularName": "employee",
    "pluralName": "employees",
    "displayName": "Employees"
  },
  "options": {},
  "attributes": {
    "first_name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "last_name": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "phone_number": {
      "type": "string",
      "required": false,
      "unique": false
    },
    "hire_date": {
      "type": "date",
      "required": true,
      "unique": false
    },
    "job_title": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "department": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "salary": {
      "type": "decimal",
      "required": true,
      "unique": false
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "unique": false,
      "default": "active",
      "enum": [
        "active",
        "inactive",
        "terminated"
      ]
    },
    "profile_picture": {
      "type": "media",
      "required": false,
      "unique": false,
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
